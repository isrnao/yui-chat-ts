{
  "name": "yui-chat-ts",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "ゆいちゃっとTSは放課後学生タウンの雰囲気を楽しめる無料のお気楽チャットです。",
  "keywords": [
    "ゆいちゃっとTS",
    "放課後学生タウン",
    "お気楽チャット",
    "無料チャット",
    "ブラウザチャット",
    "リアルタイムチャット",
    "学生チャット",
    "オンラインチャット",
    "react",
    "typescript",
    "vite",
    "chat",
    "realtime"
  ],
  "homepage": "https://www.okiraku.chat/",
  "repository": {
    "type": "git",
    "url": "https://github.com/isrnao/yui-chat-ts.git"
  },
  "author": "ゆいちゃっとTS開発チーム",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "pnpm run generate:sitemap && tsc -b && vite build && pnpm run optimize:seo",
    "generate:sitemap": "node --experimental-strip-types scripts/generate-sitemap.ts",
    "optimize:seo": "echo 'SEO最適化完了 (sitemap.xml は generate:sitemap で生成済み)'",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mdx",
    "preview": "vite preview",
    "predeploy": "pnpm run build:prod",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "watch:test": "vitest",
    "test:ui": "vitest run --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lighthouse": "lighthouse https://www.okiraku.chat/ --output html --output-path ./lighthouse-report.html",
    "lighthouse:mobile": "lighthouse https://www.okiraku.chat/ --output html --output-path ./lighthouse-mobile.html --emulated-form-factor=mobile",
    "lighthouse:desktop": "lighthouse https://www.okiraku.chat/ --output html --output-path ./lighthouse-desktop.html --emulated-form-factor=desktop",
    "lighthouse:json": "lighthouse https://www.okiraku.chat/ --output json --output-path ./lighthouse-data.json",
    "lighthouse:ci": "lighthouse https://www.okiraku.chat/ --output json --quiet --chrome-flags='--headless'",
    "analyze:bundle": "npx vite-bundle-analyzer dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --stats-json",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "chromatic:dryrun": "dotenv -e .env -- chromatic --dry-run --debug"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@types/uuid": "^10.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^10.0.1",
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@storybook/react": "^9.1.8",
    "@storybook/react-vite": "^9.1.8",
    "@tailwindcss/cli": "^4.1.8",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "3.2.3",
    "@vitest/ui": "^3.2.3",
    "@webgpu/types": "^0.1.61",
    "autoprefixer": "^10.4.21",
    "chromatic": "^13.2.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-mdx": "^3.5.0",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.7.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "lefthook": "^1.11.13",
    "lighthouse": "^12.6.1",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "sass": "^1.89.1",
    "storybook": "^9.1.8",
    "tailwindcss": "^4.1.8",
    "terser": "^5.42.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  }
}
